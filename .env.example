# agent3d 环境配置 —— 复制为 .env 后填写
# 真实环境变量优先级高于本文件

# 【必填，视觉步骤用】Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter 兼容端点（不要带 /v1）
ANTHROPIC_BASE_URL=https://openrouter.ai/api

# 【可选】视觉模型
WIDE_SIM_VISION_MODEL=anthropic/claude-opus-4.6

# 【可选】体素分辨率，块/米，默认 4.0
AGENT3D_BPM=4.0

# 【可选】产物输出根目录
# AGENT3D_SCENES=artifacts_web
